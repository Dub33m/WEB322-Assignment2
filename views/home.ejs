<!DOCTYPE html>
<html lang="en" data-theme="cupcake">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Climate Solutions</title>

    <link href="/css/main.css" rel="stylesheet">

</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container mx-auto px-14">

        <div class="hero py-10">

            <div class="hero-content text-center">

                <div>

                    <h1 class="text-5xl font-bold">

                        Climate Solutions

                    </h1>

                    <p class="py-6">

                        Explore innovative projects that help create a cleaner and more sustainable future.

                    </p>

                    <a href="/solutions/projects" class="btn btn-primary">

                        Explore Projects

                    </a>

                </div>

            </div>

        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Card 1 -->

            <div class="card bg-base-100 shadow-xl">

                <figure>

                    <img
                        src="https://drawdown.org/sites/default/files/styles/crop_to_square_1080/public/media/FY25_Solutions_LEDLighting_2400x2400.jpg?itok=viThnGFb"
                        alt="Deploy LED Lighting">

                </figure>

                <div class="card-body">

                    <h2 class="card-title">

                        Deploy LED Lighting

                    </h2>

                    <p>

                        We define the Deploy LED Lighting solution as replacing energy-inefficient light sources with light-emitting diodes (LEDs).

                    </p>

                    <div class="card-actions justify-end">

                        <a href="/solutions/projects/1" class="btn btn-primary">

                            Read More

                        </a>

                    </div>

                </div>

            </div>

            <!-- Card 2 -->

            <div class="card bg-base-100 shadow-xl">

                <figure>

                    <img
                        src="https://drawdown.org/sites/default/files/styles/crop_to_square_1080/public/media/FY25_Solutions_OffshoreWind_2400x2400.jpeg?itok=0Pxv1Csk"
                        alt="Deploy Offshore Wind Turbines">

                </figure>

                <div class="card-body">

                    <h2 class="card-title">

                        Deploy Offshore Wind Turbines

                    </h2>

                    <p>

                        Offshore wind turbines are ocean-based machines that harness natural wind to generate electricity.

                    </p>

                    <div class="card-actions justify-end">

                        <a href="/solutions/projects/2" class="btn btn-primary">

                            Read More

                        </a>

                    </div>

                </div>

            </div>

            <!-- Card 3 -->

            <div class="card bg-base-100 shadow-xl">

                <figure>

                    <img
                        src="https://drawdown.org/sites/default/files/styles/crop_to_square_1080/public/media/FY25_Solutions_OnShoreWind_2400x2400.jpeg?itok=7Mb7tq-z"
                        alt="Deploy Onshore Wind Turbines">

                </figure>

                <div class="card-body">

                    <h2 class="card-title">

                        Deploy Onshore Wind Turbines

                    </h2>

                    <p>

                        Onshore wind turbines are land-based machines that harness natural wind to generate electricity.

                    </p>

                    <div class="card-actions justify-end">

                        <a href="/solutions/projects/3" class="btn btn-primary">

                            Read More

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>